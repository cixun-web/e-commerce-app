{
  "name": "tools-inline",
  "version": "0.1.0",
  "description": "自动测试工具进行质量守护",
  "main": "./out/main/index.js",
  "author": "ci-xun",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "(chcp 65001 || true) && electron-vite preview",
    "dev": "(chcp 65001 || true) && electron-vite dev",
    "build": "(chcp 65001 || true) && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "install:browsers": "cross-env PLAYWRIGHT_BROWSERS_PATH=resources/browsers npx playwright install chromium",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@tailwindcss/vite": "^4.1.18",
    "axios": "^1.13.2",
    "echarts": "^6.0.0",
    "element-plus": "^2.12.0",
    "exceljs": "^4.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "less": "^4.5.1",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "playwright": "^1.48.0",
    "tailwindcss": "^4.1.18",
    "vue-draggable-plus": "^0.6.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "vite": "^7.2.6",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
